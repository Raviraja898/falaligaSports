rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default fallback
    match /{document=**} {
      allow read, write: if true;
    }

    // Players collection rules
    match /players/{playerId} {
      allow read: if true;
      allow write: if true;
    }

    // Owners collection rules
    match /owners/{ownerId} {
      allow read: if true;
      allow write: if true;
    }

    // Bids collection rules
    match /bids/{bidId} {
      allow read: if true;
      allow write: if true;
    }

    // Auction Status rules
    match /auction/status {
      allow read: if true;
      allow write: if true;
    }
  }
}
